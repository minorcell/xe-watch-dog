# GitHub organization to monitor.
GITHUB_ORG=

# GitHub API token. Keep this server-side only.
GITHUB_TOKEN=

# Postgres connection string for repositories, metrics, and sync runs.
DATABASE_URL=

# Protect the Vercel Cron sync endpoint.
CRON_SECRET=

# Vercel: pnpm auth:hash -- "your-password"
# Local: pnpm auth:hash-b64 -- "your-password"
ADMIN_PASSWORD_HASH=
ADMIN_PASSWORD_HASH_B64=

# Cron schedule (self-hosted/Docker only, default: daily 1am UTC)
CRON_SCHEDULE=0 1 * * *

# Generate with: pnpm auth:secret
AUTH_SECRET=
